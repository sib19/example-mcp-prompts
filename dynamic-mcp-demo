class MockKDBConnection:
“”“Mimics KDBConnection without needing a real KDB+ process.”””

```
def __init__(self):
    self.host = "mock-host"
    self.port = 9999

def connect(self):
    log.info("MockKDBConnection: connected (no real KDB+ process).")

def close(self):
    pass

def query(self, expr: str) -> Any:
    log.info("MockKDB query: %s", expr)
    for fn_name, mock_fn in _MOCK_RESULTS.items():
        if expr.startswith(fn_name):
            # Extract bracket args  fn[arg1; arg2]
            inner = expr[len(fn_name):]
            if inner.startswith("[") and inner.endswith("]"):
                raw_args = [a.strip().strip('"').strip("'")
                            for a in inner[1:-1].split(";")]
                # strip Q type coercions like `$string "AAPL" → AAPL
                args = [a.split('"')[-2] if '"' in a else a for a in raw_args]
                try:
                    return mock_fn(*args)
                except TypeError:
                    return mock_fn()
            else:
                return mock_fn()
    # fallback: count trade etc.
    return {"expr": expr, "result": "mock_result"}

def safe_query(self, expr: str, default: Any = None) -> Any:
    try:
        return self.query(expr)
    except Exception:
        return default
```

# ── Patch kdb_mcp_server to use mock objects ──────────────────────────────────

import importlib.util, pathlib, types as _types  # noqa: E402

_server_path = pathlib.Path(**file**).parent / “kdb_mcp_server.py”

# Dynamically load the server module

spec = importlib.util.spec_from_file_location(“kdb_mcp_server”, _server_path)
server_mod = importlib.util.module_from_spec(spec)

# Inject stubs before executing module body

server_mod.KDBConnection   = MockKDBConnection  # type: ignore
server_mod.introspect_functions = lambda kdb: _MOCK_FUNCTIONS  # type: ignore

spec.loader.exec_module(server_mod)

def main():
ap = argparse.ArgumentParser(description=“KDB MCP Demo (mock KDB)”)
ap.add_argument(”–sse”, action=“store_true”, help=“Use SSE transport”)
args = ap.parse_args()

