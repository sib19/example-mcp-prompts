class KDBConnection:
“”“Thin wrapper around qpython that keeps a persistent connection.”””

```
def __init__(self, host: str, port: int, user: str = "", password: str = ""):
    self.host = host
    self.port = port
    self.user = user
    self.password = password
    self._conn: Optional[qconn.QConnection] = None

# ------------------------------------------------------------------
def connect(self) -> None:
    log.info("Connecting to KDB+ %s:%s …", self.host, self.port)
    self._conn = qconn.QConnection(
        host=self.host,
        port=self.port,
        username=self.user,
        password=self.password,
        pandas=False,        # raw qpython types – we convert ourselves
    )
    self._conn.open()
    log.info("KDB+ connection established.")

# ------------------------------------------------------------------
def close(self) -> None:
    if self._conn:
        try:
            self._conn.close()
        except Exception:
            pass
        self._conn = None

# ------------------------------------------------------------------
def query(self, expr: str) -> Any:
    """Execute a Q expression and return the raw result."""
    if self._conn is None:
        raise RuntimeError("Not connected to KDB+.")
    return self._conn(expr)

# ------------------------------------------------------------------
def safe_query(self, expr: str, default: Any = None) -> Any:
    try:
        return self.query(expr)
    except Exception as exc:
        log.warning("KDB query failed [%s]: %s", expr, exc)
        return default
