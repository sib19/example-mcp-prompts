# Dynamic tool factory

# ─────────────────────────────────────────────────────────────────────────────

def register_kdb_tool(mcp: FastMCP, kdb: KDBConnection, fn_meta: Dict[str, str]) -> None:
“”“Create and register a FastMCP tool for a single KDB function.”””
name   = fn_meta[“name”]
params = fn_meta[“params”]
doc    = build_docstring(fn_meta)

```
if not params:
    # ── zero-arg function ────────────────────────────────────────────────
    @mcp.tool(name=name, description=doc)
    def _tool_no_args() -> str:
        log.info("Calling KDB function: %s[]", name)
        result = kdb.query(f"{name}[]")
        return _serialise_result(result)

else:
    # ── parameterised function ───────────────────────────────────────────
    # We build a dynamic function with the correct signature so FastMCP
    # can surface proper parameter names in the tool schema.
    param_str  = ", ".join(params)
    typed_str  = ", ".join(f'{p}: str = ""' for p in params)
    q_args_str = "; ".join([f"`$string {p}" if True else p for p in params])

    fn_source = textwrap.dedent(f"""\
        def _tool({typed_str}) -> str:
            args_q = "; ".join([
                (f'`$string "{{v}}"' if isinstance(v, str) else str(v))
                for v in [{param_str}]
            ])
            expr = f"{name}[{{args_q}}]"
            log.info("Calling KDB: %s", expr)
            result = kdb.query(expr)
            return _serialise_result(result)
    """)

    local_ns: Dict[str, Any] = {
        "log": log,
        "kdb": kdb,
        "_serialise_result": _serialise_result,
    }
    exec(fn_source, local_ns)  # noqa: S102 – controlled dynamic code
    tool_fn = local_ns["_tool"]
    tool_fn.__name__ = name
    tool_fn.__doc__  = doc

    mcp.tool(name=name, description=doc)(tool_fn)

log.info("Registered MCP tool: %s (params=%s)", name, params)
```

