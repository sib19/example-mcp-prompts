def parse_args() -> argparse.Namespace:
p = argparse.ArgumentParser(description=“Dynamic KDB+ FastMCP Server”)
p.add_argument(”–host”,     default=os.getenv(“KDB_HOST”, “localhost”))
p.add_argument(”–port”,     type=int, default=int(os.getenv(“KDB_PORT”, “5000”)))
p.add_argument(”–user”,     default=os.getenv(“KDB_USER”, “”))
p.add_argument(”–password”, default=os.getenv(“KDB_PASSWORD”, “”))
p.add_argument(”–transport”,choices=[“stdio”, “sse”], default=“stdio”,
help=“MCP transport (stdio for Claude Desktop, sse for HTTP)”)
p.add_argument(”–reload-interval”, type=int, default=0,
help=“Re-introspect KDB+ every N seconds (0 = no reload)”)
return p.parse_args()

def build_server(host: str, port: int, user: str, password: str) -> FastMCP:
“”“Connect to KDB+, introspect, and return a fully-wired FastMCP server.”””

```
kdb = KDBConnection(host=host, port=port, user=user, password=password)
kdb.connect()

# ── Server + prompt ───────────────────────────────────────────────────────
mcp = FastMCP(
    name="kdb-mcp-server",
    instructions=SERVER_PROMPT.format(host=host, port=port),
)

# ── Built-in utility tools ─────────────────────────────────────────────────
@mcp.tool(
    name="kdb_raw_query",
    description=textwrap.dedent("""\
        Execute an arbitrary Q expression on the KDB+ server and return the result as JSON.

        Use this as an escape-hatch when no dedicated tool matches your query.

        Parameters
        ----------
        expr (str): Any valid Q/KDB+ expression, e.g. 'select from trade where sym=`AAPL'.

        Returns
        -------
        str
            JSON-encoded result.

        Keywords
        --------
            kdb, raw, q expression, ad-hoc, custom query

        Sample call
        -----------
            result = await kdb_raw_query(expr="count trade")
    """),
)
def kdb_raw_query(expr: str) -> str:
    log.info("Raw KDB query: %s", expr)
    result = kdb.query(expr)
    return _serialise_result(result)

@mcp.tool(
    name="kdb_list_functions",
    description=textwrap.dedent("""\
        List all public KDB+ functions currently available as MCP tools.

        Returns
        -------
        str
            JSON array of objects with keys: name, params, doc.

        Keywords
        --------
            kdb, list, functions, tools, available, discover

        Sample call
        -----------
            result = await kdb_list_functions()
    """),
)
def kdb_list_functions() -> str:
    fns = introspect_functions(kdb)
    summary = [{"name": f["name"], "params": f["params"], "doc": f["doc"]} for f in fns]
    return json.dumps(summary, indent=2)

@mcp.tool(
    name="kdb_table_schema",
    description=textwrap.dedent("""\
        Return the column names and types for a KDB+ table.

        Parameters
        ----------
        table (str): Name of the table in the connected KDB+ namespace.

        Returns
        -------
        str
            JSON object mapping column names to Q type codes.

        Keywords
        --------
            kdb, schema, table, columns, types, metadata

        Sample call
        -----------
            result = await kdb_table_schema(table="trade")
    """),
)
def kdb_table_schema(table: str) -> str:
    result = kdb.query(f"meta {table}")
    return _serialise_result(result)

# ── Dynamically register KDB functions ────────────────────────────────────
functions = introspect_functions(kdb)
if not functions:
    log.warning("No public KDB functions found – only built-in tools registered.")
for fn_meta in functions:
    try:
        register_kdb_tool(mcp, kdb, fn_meta)
    except Exception as exc:
        log.error("Failed to register tool %s: %s", fn_meta["name"], exc)

log.info(
    "FastMCP server ready with %d tool(s) (%d from KDB+, 3 built-in).",
    len(functions) + 3, len(functions),
)
return mcp
