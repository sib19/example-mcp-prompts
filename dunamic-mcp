# Q snippet that returns a keyed-table of user-defined functions:

# name | params | body | doc

_INTROSPECT_Q = r”””
{[]
fns: {x where {.q[x]~`function} each {type value x} each x} key `.;
t: {[f]
v:  value f;
ps: $[4h=type v 1; string v 1; enlist “args”];
bd: $[4<=count v; -3!v 4; “”];
dc: $[0h=type v 0; (v 0); “”];
(f; ps; bd; dc)
} each fns;
flip `name`params`body`doc!(fns; {x[1]} each t; {x[2]} each t; {x[3]} each t)
}[]
“””

# Simpler fallback – just list public lambda names

_LIST_LAMBDAS_Q = r”string each {x where {100h=type value x} each x} key `.”

def _qval_to_python(val: Any) -> Any:
“”“Recursively convert qpython native types to plain Python objects.”””
if isinstance(val, (np.ndarray,)):
return [_qval_to_python(v) for v in val.tolist()]
if isinstance(val, QDictionary):
return {_qval_to_python(k): _qval_to_python(v)
for k, v in zip(val.keys(), val.values())}
if isinstance(val, QTable):
cols = [c.decode() if isinstance(c, bytes) else str(c) for c in val.dtype.names]
rows = []
for row in val:
rows.append({c: *qval_to_python(row[c]) for c in cols})
return rows
if isinstance(val, bytes):
return val.decode(errors=“replace”)
if isinstance(val, (np.integer,)):
return int(val)
if isinstance(val, (np.floating,)):
return float(val)
if isinstance(val, (np.bool*,)):
return bool(val)
return val

def introspect_functions(kdb: KDBConnection) -> List[Dict[str, str]]:
“””
Return a list of dicts with keys: name, params (list[str]), body, doc.
Falls back to a simpler listing if the full introspection query fails.
“””
result = kdb.safe_query(_INTROSPECT_Q)
functions: List[Dict[str, str]] = []

```
if result is not None:
    rows = _qval_to_python(result)
    if isinstance(rows, list):
        for row in rows:
            functions.append({
                "name":   str(row.get("name", "unknown")),
                "params": _normalise_params(row.get("params", [])),
                "body":   str(row.get("body", "")),
                "doc":    str(row.get("doc", "")),
            })
        log.info("Introspected %d KDB functions (full mode).", len(functions))
        return functions

# ── fallback ─────────────────────────────────────────────────────────────
log.warning("Full introspection failed – using lightweight fallback.")
names_raw = kdb.safe_query(_LIST_LAMBDAS_Q, default=[])
names = _qval_to_python(names_raw) if names_raw is not None else []
for name in names:
    if isinstance(name, str) and name:
        params_raw = kdb.safe_query(
            f"string (value {name}) 1", default=[]
        )
        functions.append({
            "name":   name,
            "params": _normalise_params(_qval_to_python(params_raw)),
            "body":   "",
            "doc":    "",
        })
log.info("Introspected %d KDB functions (fallback mode).", len(functions))
return functions
```

def _normalise_params(raw: Any) -> List[str]:
if isinstance(raw, list):
return [str(p) for p in raw if p]
if isinstance(raw, str) and raw:
return [raw]
return []

